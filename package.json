{
  "name": "ai-scheduler-desktop",
  "version": "1.0.0",
  "description": "Omniscient AI Scheduler Native Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "echo 'Backend: no build needed'",
    "dev": "concurrently \"cd scheduler-frontend && npm run dev\" \"cd scheduler-backend && npx nodemon src/app.js\" \"npm run tunnel\" \"wait-on http://localhost:5173 && electron .\"",
    "tunnel": "npx lt --port 5173 --subdomain omniscient-scheduler",
    "sync-dev": "concurrently \"npm run dev\" \"npm run tunnel\"",
    "build:frontend": "npm run build --prefix scheduler-frontend",
    "postinstall": "npm install --prefix scheduler-frontend && npm install --prefix scheduler-backend",
    "package": "npm run build:frontend && electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "node-notifier": "^10.0.1",
    "pg": "^8.20.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^13.0.0",
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0",
    "electron-builder": "^24.6.0",
    "nodemon": "^3.1.14"
  }
}

